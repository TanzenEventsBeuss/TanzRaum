export const sb = createClient(SUPABASE_URL, SUPABASE_ANON);

// ── Mappers: DB row → app object ──────────────────────────────────────────
export const mapLocation = r => ({ id: r.id, name: r.name, address: r.address || "" });
export const mapRoom     = r => ({ id: r.id, name: r.name, location: r.location_id, cap: r.capacity, area: r.area_sqm, features: r.features || "", color: r.color || "#ff3c6e" });
export const mapCourse   = r => ({ id: r.id, name: r.name, room: r.room_id, start: r.start_time, end: r.end_time, recurType: r.recur_type, days: r.days || [], validFrom: r.valid_from, validTo: r.valid_to || "", onceDate: r.once_date || "", instructor: r.instructor || "", note: r.note || "", price: parseFloat(r.price) || 0 });
export const mapSlot     = r => ({ id: r.id, room: r.room_id, title: r.title, type: r.type, date: r.slot_date, start: r.start_time, end: r.end_time, customer: r.customer || "", note: r.note || "", price: parseFloat(r.price) || 0 });
export const mapTeacher  = r => ({ id: r.id, firstName: r.first_name, lastName: r.last_name, email: r.email || "", phone: r.phone || "", spec: r.speciality || "", password: r.password, active: r.active });

// ── Load all tables ───────────────────────────────────────────────────────
export async function loadAll() {
  const [locR, roomR, courseR, slotR, teachR] = await Promise.all([
    sb.from("locations").select("*").order("name"),
    sb.from("rooms").select("*").order("name"),
    sb.from("courses").select("*").order("name"),
    sb.from("slots").select("*").order("slot_date"),
    sb.from("teachers").select("*").order("last_name"),
  ]);
  if (locR.error || roomR.error || courseR.error || slotR.error || teachR.error) {
    const err = locR.error || roomR.error || courseR.error || slotR.error || teachR.error;
    throw new Error(err.message);
  }
  return {
    locations: locR.data.map(mapLocation),
    rooms:     roomR.data.map(mapRoom),
    courses:   courseR.data.map(mapCourse),
    slots:     slotR.data.map(mapSlot),
    teachers:  teachR.data.map(mapTeacher),
  };
}

// ── Slots ─────────────────────────────────────────────────────────────────
export async function dbSaveSlot(slot) {
  const row = { room_id: slot.room, title: slot.title, type: slot.type, slot_date: slot.date, start_time: slot.start, end_time: slot.end, customer: slot.customer || null, note: slot.note || null, price: slot.price || 0 };
  if (slot.id) {
    const { error } = await sb.from("slots").update(row).eq("id", slot.id);
    return error ? null : slot.id;
  } else {
    const { data, error } = await sb.from("slots").insert(row).select("id").single();
    return error ? null : data.id;
  }
}
export async function dbDeleteSlot(id)                    { const { error } = await sb.from("slots").delete().eq("id", id); return !error; }
export async function dbUpdateSlotType(id, type, customer = "") { const { error } = await sb.from("slots").update({ type, customer }).eq("id", id); return !error; }

// ── Courses ───────────────────────────────────────────────────────────────
export async function dbSaveCourse(course) {
  const row = { name: course.name, room_id: course.room, start_time: course.start, end_time: course.end, recur_type: course.recurType, days: course.days, valid_from: course.recurType === "once" ? course.onceDate : course.validFrom, valid_to: course.recurType === "once" ? course.onceDate : (course.validTo || null), once_date: course.recurType === "once" ? course.onceDate : null, instructor: course.instructor || null, note: course.note || null, price: course.price || 0 };
  if (course.id) {
    const { error } = await sb.from("courses").update(row).eq("id", course.id);
    return !error;
  } else {
    const { error } = await sb.from("courses").insert(row);
    return !error;
  }
}
export async function dbDeleteCourse(id) { const { error } = await sb.from("courses").delete().eq("id", id); return !error; }

// ── Rooms ─────────────────────────────────────────────────────────────────
export async function dbSaveRoom(room) {
  const row = { name: room.name, location_id: room.location || null, capacity: room.cap, area_sqm: room.area, features: room.features, color: room.color };
  const { error } = await sb.from("rooms").insert(row);
  return !error;
}
export async function dbDeleteRoom(id) { const { error } = await sb.from("rooms").delete().eq("id", id); return !error; }

// ── Teachers ──────────────────────────────────────────────────────────────
export async function dbSaveTeacher(t) {
  const row = { first_name: t.firstName, last_name: t.lastName, email: t.email || null, phone: t.phone || null, speciality: t.spec || null, password: t.password, active: t.active };
  if (t.id) {
    const { error } = await sb.from("teachers").update(row).eq("id", t.id);
    return !error;
  } else {
    const { error } = await sb.from("teachers").insert(row);
    return !error;
  }
}
export async function dbDeleteTeacher(id)              { const { error } = await sb.from("teachers").delete().eq("id", id); return !error; }
export async function dbUpdateTeacherActive(id, active) { const { error } = await sb.from("teachers").update({ active }).eq("id", id); return !error; }
export async function dbUpdateTeacherPw(id, password)   { const { error } = await sb.from("teachers").update({ password }).eq("id", id); return !error; }

// ── Locations ─────────────────────────────────────────────────────────────
export async function dbSaveLocation(loc) {
  const row = { name: loc.name, address: loc.address || null };
  if (loc.id) {
    const { error } = await sb.from("locations").update(row).eq("id", loc.id);
    return !error;
  } else {
    const { error } = await sb.from("locations").insert(row);
    return !error;
  }
}
export async function dbDeleteLocation(id) {
  const { error } = await sb.from("locations").delete().eq("id", id);
  return !error;
}
export async function dbInsertBookingRequest(slotId, { firstName, lastName, email, phone, message }) {
  const { error } = await sb.from("booking_requests").insert({ slot_id: slotId, first_name: firstName, last_name: lastName, email, phone: phone || null, message: message || null });
  return !error;
}
export async function dbLoadBookingRequests() {
  const { data, error } = await sb.from("booking_requests").select("*,slots(title,slot_date,start_time,end_time,room_id)").eq("status", "pending").order("submitted_at");
  return error ? [] : data;
}
export async function dbUpdateBookingStatus(id, status) { const { error } = await sb.from("booking_requests").update({ status }).eq("id", id); return !error; }
